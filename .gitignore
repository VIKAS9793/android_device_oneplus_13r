# Ignore everything
*

# But not these files
!.gitignore
!Android.mk
!BoardConfig.mk
!device.mk
!manifest.xml
!proprietary-files.txt
!README.md

# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Log Files
*.log
*.log.*
*.tmp
*.orig
*.rej
*.patch
*.diff
*.bak
*.swp
*~

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
.vscode/
*.iws
*.ipr
.project
.classpath
.settings/

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# Build artifacts
*.o
*.ko
*.obj
*.elf
*.bin
*.img
*.zip
*.tar
*.gz
*.tgz
*.rar
*.7z

# Local configuration
local_manifest.xml
local_products.mk

# Prebuilt files
prebuilt/
vendor/

# Empty directories
audio/
prebuilt/

# LineageOS specific
lineage_*.zip
lineage_*.md5sum
lineage_*.sha256sum 